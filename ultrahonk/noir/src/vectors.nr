//! Frozen parity vectors.
//!
//! Single source of truth shared with the Rust reference (`../rust`) and the JSON
//! in `../vectors/client_ref.json`. These outputs were produced by the **real**
//! nf4 gadgets via `nf_curves` Baby JubJub + `jf_primitives::Poseidon`
//! (`derive_key.rs`, `verify_commitments_gadgets.rs`, `kemdem_gadgets.rs`,
//! `verify_nullifiers_gadgets.rs`). The Noir circuit must reproduce them
//! bit-for-bit; `tests.nr` enforces this.

// ---- inputs ----
pub global IN_ROOT_KEY: Field = 31337;
pub global IN_EPHEMERAL: Field = 555555;
pub global IN_NF_TOKEN_ID: Field = 7;
pub global IN_NF_SLOT_ID: Field = 3;
pub global IN_VALUE: Field = 1000;
pub global IN_SECRET_PREIMAGE: [Field; 3] = [11, 22, 33];

